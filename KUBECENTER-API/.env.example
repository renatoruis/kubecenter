# Server
PORT=3000
LOG_LEVEL=info

# Namespaces to watch (comma-separated)
WATCH_NAMESPACES=default

# Kubernetes authentication: auto | cluster | kubeconfig
K8S_AUTH=auto

# Path to kubeconfig file (only for K8S_AUTH=kubeconfig)
# KUBECONFIG_PATH=./kubeconfig.yaml

# Kube context to use (only for K8S_AUTH=kubeconfig)
# KUBE_CONTEXT=my-context

# API authentication token (optional, leave empty for no auth)
# API_TOKEN=
